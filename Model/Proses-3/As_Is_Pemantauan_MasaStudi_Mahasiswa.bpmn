        <dc:Bounds x="1562" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1601" y="213.5" width="57" height="53" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_EksporUNISIS" bpmnElement="T_EksporUNISIS">
        <dc:Bounds x="310" y="200" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_RekapExcel" bpmnElement="T_RekapExcel">
        <dc:Bounds x="480" y="200" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_IdentifikasiSem14" bpmnElement="T_IdentifikasiSem14">
        <dc:Bounds x="650" y="200" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_AdaMahasiswaKritis" bpmnElement="GW_AdaMahasiswaKritis" isMarkerVisible="true">
        <dc:Bounds x="825" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="885" y="226" width="78" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_ReviewRekap" bpmnElement="T_ReviewRekapitulasiManual">
        <dc:Bounds x="900" y="385" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_RapatKoord" bpmnElement="T_RapatKoordinasiPA">
        <dc:Bounds x="1060" y="385" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_PAHubungi" bpmnElement="T_PAHubungiMahasiswa">
        <dc:Bounds x="900" y="570" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_CariKontakManual" bpmnElement="T_CariKontakManual">
        <dc:Bounds x="1060" y="200" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_GW_KontakBerhasil" bpmnElement="GW_KontakBerhasil" isMarkerVisible="true">
        <dc:Bounds x="1235" y="215" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1237" y="186.5" width="46" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="S_T_KirimSuratFisik" bpmnElement="T_KirimSuratFisik">
        <dc:Bounds x="1370" y="200" width="120" height="80" />
      </bpmndi:BPMNShape>
