<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/" xmlns:camunda="http://camunda.org/schema/1.0/dmn" id="Definitions_TierMasaStudi" name="KlasifikasiTierPemantauanMasaStudi" namespace="http://camunda.org/schema/1.0/dmn">
  <decision id="DecisionTierKlasifikasi" name="Penentuan Tier Early Warning Masa Studi" camunda:historyTimeToLive="30">
    <decisionTable id="DT_TierKlasifikasi" hitPolicy="FIRST">
      <input id="Input_Semester" label="Semester Aktif" camunda:inputVariable="semesterAktif">
        <inputExpression id="InputExpr_Semester" typeRef="integer">
          <text>semesterAktif</text>
        </inputExpression>
      </input>
      <output id="Output_Tier" label="Tier Level" name="tier" typeRef="integer" />
      <rule id="Rule_Tier3">
        <inputEntry id="IE_T3">
          <text>&gt;= 14</text>
        </inputEntry>
        <outputEntry id="OE_T3_Tier">
          <text>3</text>
        </outputEntry>
      </rule>
      <rule id="Rule_Tier2">
        <inputEntry id="IE_T2">
          <text>12, 13</text>
        </inputEntry>
        <outputEntry id="OE_T2_Tier">
          <text>2</text>
        </outputEntry>
      </rule>
      <rule id="Rule_Tier1">
        <inputEntry id="IE_T1">
          <text>9, 10, 11</text>
        </inputEntry>
        <outputEntry id="OE_T1_Tier">
          <text>1</text>
        </outputEntry>
      </rule>
      <rule id="Rule_Normal">
        <inputEntry id="IE_Normal">
          <text>-</text>
        </inputEntry>
        <outputEntry id="OE_Normal_Tier">
          <text>0</text>
        </outputEntry>
      </rule>
    </decisionTable>
  </decision>
</definitions>