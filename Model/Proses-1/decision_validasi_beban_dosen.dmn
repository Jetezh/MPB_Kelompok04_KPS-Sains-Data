<?xml version="1.0" encoding="UTF-8"?>
<definitions xmlns="https://www.omg.org/spec/DMN/20191111/MODEL/"
  xmlns:dmndi="https://www.omg.org/spec/DMN/20191111/DMNDI/"
  xmlns:dc="http://www.omg.org/spec/DMN/20180521/DC/"
  id="Definitions_ValidasiBebanDosen"
  name="Validasi Beban Dosen Pengampu MK"
  namespace="http://fik.prodi.bpm/dmn/validasi-beban-dosen"
  exporter="Camunda Modeler"
  exporterVersion="5.44.0">

  <decision id="Decision_ValidasiBeban" name="Validasi Beban dan Konflik Jadwal Dosen">
    <decisionTable id="DT_ValidasiBeban" hitPolicy="FIRST">

      <!-- INPUT 1: Total SKS semester ini (termasuk MK baru) -->
      <input id="Input_TotalSKS" label="Total Beban SKS">
        <inputExpression id="InputExpr_TotalSKS" typeRef="integer">
          <text>totalBebanSKS</text>
        </inputExpression>
      </input>

      <!-- INPUT 2: Jumlah MK yang diampu semester ini -->
      <input id="Input_JumlahMK" label="Jumlah MK Diampu">
        <inputExpression id="InputExpr_JumlahMK" typeRef="integer">
          <text>jumlahMKDiampu</text>
        </inputExpression>
      </input>

      <!-- INPUT 3: Apakah MK dijadwalkan di hari Senin? -->
      <input id="Input_JadwalSenin" label="Dijadwalkan Hari Senin?">
        <inputExpression id="InputExpr_JadwalSenin" typeRef="boolean">
          <text>dijadwalkanSenin</text>
        </inputExpression>
      </input>

      <!-- INPUT 4: Apakah ada bentrok jadwal dengan MK lain? -->
      <input id="Input_BentrokJadwal" label="Bentrok Jadwal?">
        <inputExpression id="InputExpr_BentrokJadwal" typeRef="boolean">
          <text>adaBentrokJadwal</text>
        </inputExpression>
      </input>

      <!-- OUTPUT 1: Ada violation? -->
      <output id="Output_AdaViolation" label="Ada Violation" name="adaViolation" typeRef="boolean" />

      <!-- OUTPUT 2: Jenis violation -->
      <output id="Output_JenisViolation" label="Jenis Violation" name="jenisViolation" typeRef="string" />

      <!-- OUTPUT 3: Tindakan -->
      <output id="Output_Tindakan" label="Tindakan" name="tindakanPlotting" typeRef="string" />

      <!-- Rule 1: Bentrok jadwal — prioritas tertinggi -->
      <rule id="Rule_Bentrok">
        <description>Bentrok jadwal dengan MK lain: harus segera diresolvsi</description>
        <inputEntry id="IE_R1_SKS"><text></text></inputEntry>
        <inputEntry id="IE_R1_MK"><text></text></inputEntry>
        <inputEntry id="IE_R1_Senin"><text></text></inputEntry>
        <inputEntry id="IE_R1_Bentrok"><text>true</text></inputEntry>
        <outputEntry id="OE_R1_Violation"><text>true</text></outputEntry>
        <outputEntry id="OE_R1_Jenis"><text>"Bentrok Jadwal"</text></outputEntry>
        <outputEntry id="OE_R1_Tindakan"><text>"Pindahkan jadwal atau ganti dosen — tidak boleh dilanjutkan"</text></outputEntry>
      </rule>

      <!-- Rule 2: Jadwal Senin — blokir rapat dosen -->
      <rule id="Rule_Senin">
        <description>Hari Senin diblokir untuk rapat dosen, tidak boleh ada perkuliahan</description>
        <inputEntry id="IE_R2_SKS"><text></text></inputEntry>
        <inputEntry id="IE_R2_MK"><text></text></inputEntry>
        <inputEntry id="IE_R2_Senin"><text>true</text></inputEntry>
        <inputEntry id="IE_R2_Bentrok"><text></text></inputEntry>
        <outputEntry id="OE_R2_Violation"><text>true</text></outputEntry>
        <outputEntry id="OE_R2_Jenis"><text>"Jadwal Senin Terblokir"</text></outputEntry>
        <outputEntry id="OE_R2_Tindakan"><text>"Pindahkan ke hari lain — Senin khusus rapat dosen"</text></outputEntry>
      </rule>

      <!-- Rule 3: SKS Overload (> 16 SKS) -->
      <rule id="Rule_SKSOverload">
        <description>Dosen melebihi batas maksimal 16 SKS per semester</description>
        <inputEntry id="IE_R3_SKS"><text>&gt; 16</text></inputEntry>
        <inputEntry id="IE_R3_MK"><text></text></inputEntry>
        <inputEntry id="IE_R3_Senin"><text></text></inputEntry>
        <inputEntry id="IE_R3_Bentrok"><text></text></inputEntry>
        <outputEntry id="OE_R3_Violation"><text>true</text></outputEntry>
        <outputEntry id="OE_R3_Jenis"><text>"Overload SKS"</text></outputEntry>
        <outputEntry id="OE_R3_Tindakan"><text>"Kurangi beban atau distribusikan ke dosen lain"</text></outputEntry>
      </rule>

      <!-- Rule 4: MK Overload (> 5 MK) -->
      <rule id="Rule_MKOverload">
        <description>Dosen mengampu lebih dari 5 mata kuliah per semester</description>
        <inputEntry id="IE_R4_SKS"><text></text></inputEntry>
        <inputEntry id="IE_R4_MK"><text>&gt; 5</text></inputEntry>
        <inputEntry id="IE_R4_Senin"><text></text></inputEntry>
        <inputEntry id="IE_R4_Bentrok"><text></text></inputEntry>
        <outputEntry id="OE_R4_Violation"><text>true</text></outputEntry>
        <outputEntry id="OE_R4_Jenis"><text>"Overload Jumlah MK"</text></outputEntry>
        <outputEntry id="OE_R4_Tindakan"><text>"Maksimal 5 MK — alihkan sebagian ke dosen lain"</text></outputEntry>
      </rule>

      <!-- Rule 5: SKS mendekati batas (13-16) — warning -->
      <rule id="Rule_SKSWarning">
        <description>Beban SKS mendekati batas, perlu perhatian tapi masih boleh</description>
        <inputEntry id="IE_R5_SKS"><text>[13..16]</text></inputEntry>
        <inputEntry id="IE_R5_MK"><text></text></inputEntry>
        <inputEntry id="IE_R5_Senin"><text>false</text></inputEntry>
        <inputEntry id="IE_R5_Bentrok"><text>false</text></inputEntry>
        <outputEntry id="OE_R5_Violation"><text>false</text></outputEntry>
        <outputEntry id="OE_R5_Jenis"><text>"Warning: Mendekati Batas SKS"</text></outputEntry>
        <outputEntry id="OE_R5_Tindakan"><text>"Lanjutkan dengan catatan — hindari penambahan MK lagi"</text></outputEntry>
      </rule>

      <!-- Rule 6: Normal — semua aman -->
      <rule id="Rule_Normal">
        <description>Semua parameter dalam batas normal</description>
        <inputEntry id="IE_R6_SKS"><text>&lt;= 12</text></inputEntry>
        <inputEntry id="IE_R6_MK"><text>&lt;= 5</text></inputEntry>
        <inputEntry id="IE_R6_Senin"><text>false</text></inputEntry>
        <inputEntry id="IE_R6_Bentrok"><text>false</text></inputEntry>
        <outputEntry id="OE_R6_Violation"><text>false</text></outputEntry>
        <outputEntry id="OE_R6_Jenis"><text>"Tidak Ada Violation"</text></outputEntry>
        <outputEntry id="OE_R6_Tindakan"><text>"Plotting aman — lanjutkan ke draft"</text></outputEntry>
      </rule>

    </decisionTable>
  </decision>

  <dmndi:DMNDI>
    <dmndi:DMNDiagram id="DMNDiagram_BebanDosen">
      <dmndi:DMNShape id="DMNShape_ValidasiBeban" dmnElementRef="Decision_ValidasiBeban">
        <dc:Bounds height="80" width="180" x="160" y="100" />
      </dmndi:DMNShape>
    </dmndi:DMNDiagram>
  </dmndi:DMNDI>

</definitions>
