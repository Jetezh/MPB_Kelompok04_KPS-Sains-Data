<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" targetNamespace="http://fik.prodi.bpm/pemilihan-pembimbing-as-is" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:collaboration id="AsIs_Pemilihan_Pembimbing_TA">
    <bpmn:participant id="Pool_Proses" name="Proses Pemilihan Dosen Pembimbing TA (AS-IS)" processRef="Process_AsIs" />
    <bpmn:textAnnotation id="TextAnn_JapriProblem">
      <bpmn:text>Tidak ada SLA respons. Pembimbing bisa tidak membalas berhari-hari tanpa konsekuensi sistem.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnn_ExcelRisk">
      <bpmn:text>Kuota dicek manual via Excel — tidak real-time. Mahasiswa bisa diabaikan pembimbing yang sudah penuh.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnn_NoAudit">
      <bpmn:text>Persetujuan verbal/japri — tidak ada audit trail resmi. Rentan penyangkalan.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Ann_Excel" sourceRef="TextAnn_ExcelRisk" targetRef="Task_CekKuotaManual" />
    <bpmn:association id="Assoc_Ann_NoAudit" sourceRef="TextAnn_NoAudit" targetRef="Gateway_PembimbingSetuju" />
    <bpmn:association id="Assoc_Ann_Japri" sourceRef="TextAnn_JapriProblem" targetRef="Task_HubungiPembimbing" />
  </bpmn:collaboration>
  <bpmn:process id="Process_AsIs" name="Pemilihan Pembimbing TA - AS-IS" isExecutable="true">
    <bpmn:documentation>Proses pemilihan dosen pembimbing TA pada kondisi saat ini (AS-IS) di Koordinator Program Studi FIK. Diawali saat mahasiswa mencapai 130 SKS dan diakhiri dengan terdaftarnya pembimbing di sistem Lentera. Proses bersifat hybrid: sebagian manual (formulir fisik, komunikasi japri/lisan) dan sebagian digital (input Lentera). Tiga bottleneck utama: Quota Blindness (tidak ada visibilitas kuota real-time), Japri Culture (persetujuan tanpa audit trail), dan Data Silo UNISIS (database desktop tidak terhubung ke web).</bpmn:documentation>
    <bpmn:laneSet id="LaneSet_AsIs">
      <bpmn:lane id="Lane_Mahasiswa" name="Mahasiswa">
        <bpmn:documentation>Aktor utama yang mengajukan permintaan pembimbing TA. Bertanggung jawab menghubungi calon pembimbing secara informal dan mengisi serta menyerahkan formulir fisik ke admin.</bpmn:documentation>
        <bpmn:flowNodeRef>StartEvent_MencapaiSKS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_DitolakSKS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_MenemuiPA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_HubungiPembimbing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CariPembimbingLain</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_IsiFormulirFisik</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SerahkanFormulir</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DosenPA" name="Dosen PA (Penasehat Akademik)">
        <bpmn:documentation>Dosen Penasehat Akademik yang bertugas memverifikasi kelayakan akademik mahasiswa berdasarkan data KHS secara manual dari sistem UNISIS (desktop).</bpmn:documentation>
        <bpmn:flowNodeRef>Task_VerifikasiKHSManual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_SKSMemenuhi</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DosenPembimbing" name="Dosen Pembimbing TA">
        <bpmn:documentation>Dosen calon pembimbing. Memberikan persetujuan secara verbal atau japri tanpa mekanisme formal. Tidak memiliki akses ke data kuota real-time.</bpmn:documentation>
        <bpmn:flowNodeRef>Task_PembimbingPertimbangkan</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PembimbingSetuju</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_AdminProdi" name="Admin Prodi (Mikmas)">
        <bpmn:documentation>Staf administrasi Prodi yang mengecek kuota manual via Excel, memverifikasi kelengkapan formulir fisik, dan menginput data ke Lentera.</bpmn:documentation>
        <bpmn:flowNodeRef>Task_CekKuotaManual</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_KuotaTersedia</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_VerifikasiDokumen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_InputDataLentera</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_PembimbingTerdaftar</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_MencapaiSKS" name="Mahasiswa Mencapai&#10;130 SKS">
      <bpmn:documentation>Trigger awal proses. Tidak ada deteksi otomatis; mahasiswa sendiri yang harus menyadari telah memenuhi syarat dan proaktif mendatangi Dosen PA.</bpmn:documentation>
      <bpmn:outgoing>Flow_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:endEvent id="EndEvent_DitolakSKS" name="Proses Dibatalkan&#10;(SKS Tidak Memenuhi)">
      <bpmn:documentation>Proses dihentikan karena mahasiswa belum mencapai 130 SKS. Mahasiswa harus mengulang semester berikutnya.</bpmn:documentation>
      <bpmn:incoming>Flow_04</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:manualTask id="Task_MenemuiPA" name="Menemui Dosen PA&#10;untuk Konsultasi KHS">
      <bpmn:documentation>Mahasiswa mendatangi Dosen PA secara langsung untuk meminta verifikasi kelayakan. Tidak ada penjadwalan formal. Sepenuhnya manual tanpa jejak digital.</bpmn:documentation>
      <bpmn:incoming>Flow_01</bpmn:incoming>
      <bpmn:outgoing>Flow_02</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:userTask id="Task_VerifikasiKHSManual" name="Verifikasi KHS Secara&#10;Manual (Hitung SKS)">
      <bpmn:documentation>Dosen PA memeriksa dokumen KHS secara manual untuk menghitung total SKS. Rentan human error. Data dari UNISIS (desktop) harus dibuka terpisah.</bpmn:documentation>
      <bpmn:incoming>Flow_02</bpmn:incoming>
      <bpmn:outgoing>Flow_03</bpmn:outgoing>
      <bpmn:property id="Property_0c7zsle" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_0wjj05p">
        <bpmn:sourceRef>DataRef_KHS</bpmn:sourceRef>
        <bpmn:targetRef>Property_0c7zsle</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_SKSMemenuhi" name="SKS ≥ 130?">
      <bpmn:documentation>Keputusan berdasarkan hasil verifikasi manual Dosen PA. Ya: lanjut ke pencarian pembimbing. Tidak: proses dibatalkan.</bpmn:documentation>
      <bpmn:incoming>Flow_03</bpmn:incoming>
      <bpmn:outgoing>Flow_05</bpmn:outgoing>
      <bpmn:outgoing>Flow_04</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="Task_HubungiPembimbing" name="Hubungi Calon Pembimbing&#10;via Japri / Lisan">
      <bpmn:documentation>Mahasiswa menghubungi calon pembimbing via WhatsApp atau tatap muka. Tidak ada jalur resmi, tidak ada batas waktu respons, tidak ada audit trail.</bpmn:documentation>
      <bpmn:incoming>Flow_05</bpmn:incoming>
      <bpmn:outgoing>Flow_06</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:userTask id="Task_PembimbingPertimbangkan" name="Pembimbing&#10;Mempertimbangkan&#10;Permintaan">
      <bpmn:documentation>Dosen mempertimbangkan permintaan supervisi. Tidak memiliki akses kuota real-time sehingga keputusan bergantung pada perkiraan subjektif.</bpmn:documentation>
      <bpmn:incoming>Flow_06</bpmn:incoming>
      <bpmn:outgoing>Flow_07</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_PembimbingSetuju" name="Pembimbing&#10;Setuju?">
      <bpmn:documentation>Keputusan berdasarkan respons verbal/japri dosen. Tidak ada SLA. Persetujuan informal dan dapat dibatalkan tanpa konsekuensi sistem.</bpmn:documentation>
      <bpmn:incoming>Flow_07</bpmn:incoming>
      <bpmn:outgoing>Flow_08</bpmn:outgoing>
      <bpmn:outgoing>Flow_09</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="Task_CariPembimbingLain" name="Cari Calon Pembimbing&#10;Lain (Japri Ulang)">
      <bpmn:documentation>Mahasiswa mengulangi pencarian secara informal. Tidak ada sistem rekomendasi atau daftar pembimbing tersedia yang bisa diakses mahasiswa.</bpmn:documentation>
      <bpmn:incoming>Flow_09</bpmn:incoming>
      <bpmn:incoming>Flow_13</bpmn:incoming>
      <bpmn:outgoing>Flow_10</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:userTask id="Task_CekKuotaManual" name="Admin Cek Kuota&#10;Manual (via Excel)">
      <bpmn:documentation>Admin membuka file Excel rekap kuota untuk memverifikasi sisa kapasitas dosen (batas 10 mahasiswa). Tidak akurat karena file tidak terupdate real-time.</bpmn:documentation>
      <bpmn:incoming>Flow_08</bpmn:incoming>
      <bpmn:outgoing>Flow_11</bpmn:outgoing>
      <bpmn:property id="Property_1lvwdgq" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1oqnpp7">
        <bpmn:sourceRef>DataRef_ExcelKuota</bpmn:sourceRef>
        <bpmn:targetRef>Property_1lvwdgq</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="Gateway_KuotaTersedia" name="Kuota&#10;Tersedia?">
      <bpmn:documentation>Keputusan berdasarkan pengecekan manual Admin. Jika penuh, mahasiswa harus kembali mencari pembimbing lain — menyebabkan loop yang membuang waktu.</bpmn:documentation>
      <bpmn:incoming>Flow_11</bpmn:incoming>
      <bpmn:outgoing>Flow_12</bpmn:outgoing>
      <bpmn:outgoing>Flow_13</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:manualTask id="Task_IsiFormulirFisik" name="Mahasiswa Mengisi&#10;Formulir Fisik TA">
      <bpmn:documentation>Mahasiswa mengisi formulir kertas (data diri, NIM, judul TA, nama Pembimbing 1 dan 2). Tidak ada validasi format otomatis; kesalahan pengisian sering terjadi.</bpmn:documentation>
      <bpmn:incoming>Flow_12</bpmn:incoming>
      <bpmn:outgoing>Flow_14</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOut_FormulirIsi">
        <bpmn:targetRef>DataRef_FormulirFisik</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:manualTask>
    <bpmn:userTask id="Task_VerifikasiDokumen" name="Admin Verifikasi&#10;Kelengkapan Dokumen">
      <bpmn:documentation>Admin memeriksa kelengkapan formulir: kesesuaian NIM, isian semua kolom wajib. Jika ada kekurangan, mahasiswa diminta melengkapi dan menyerahkan kembali.</bpmn:documentation>
      <bpmn:incoming>Flow_15</bpmn:incoming>
      <bpmn:outgoing>Flow_16a</bpmn:outgoing>
      <bpmn:property id="Property_0okzk4o" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_0ftqruw">
        <bpmn:sourceRef>DataRef_FormulirFisik</bpmn:sourceRef>
        <bpmn:targetRef>Property_0okzk4o</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:dataObjectReference id="DataRef_ExcelKuota" name="Rekap Kuota Pembimbing (Excel)" dataObjectRef="DataObject_ExcelKuota">
      <bpmn:documentation>File Excel manual melacak jumlah mahasiswa per dosen (batas 10). Tidak sinkron real-time — sering tidak akurat dan menyebabkan over-capacity.</bpmn:documentation>
    </bpmn:dataObjectReference>
    <bpmn:dataObject id="DataObject_ExcelKuota" />
    <bpmn:manualTask id="Task_SerahkanFormulir" name="Serahkan Formulir&#10;ke Admin Prodi">
      <bpmn:documentation>Mahasiswa menyerahkan formulir fisik ke Admin Prodi secara langsung. Admin harus hadir di tempat. Tidak ada sistem antrian atau tanda terima digital.</bpmn:documentation>
      <bpmn:incoming>Flow_14</bpmn:incoming>
      <bpmn:outgoing>Flow_15</bpmn:outgoing>
    </bpmn:manualTask>
    <bpmn:userTask id="Task_InputDataLentera" name="Input Data Pembimbing&#10;ke Sistem Lentera">
      <bpmn:documentation>Admin menginput data pembimbing TA ke Lentera secara manual berdasarkan formulir fisik. Rentan kesalahan pengetikan dan keterlambatan karena bergantung ketersediaan admin.</bpmn:documentation>
      <bpmn:incoming>Flow_16a</bpmn:incoming>
      <bpmn:outgoing>Flow_16</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOut_Lentera">
        <bpmn:targetRef>DataRef_DataLentera</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:dataObjectReference id="DataRef_DataLentera" name="Data Bimbingan di Lentera" dataObjectRef="DataObject_DataLentera">
      <bpmn:documentation>Record digital pembimbing TA di sistem Lentera. Diinput manual oleh Admin dari formulir fisik. Tidak terhubung otomatis ke UNISIS sehingga sering tidak sinkron.</bpmn:documentation>
    </bpmn:dataObjectReference>
    <bpmn:dataObject id="DataObject_DataLentera" />
    <bpmn:endEvent id="EndEvent_PembimbingTerdaftar" name="Pembimbing TA&#10;Terdaftar di Lentera">
      <bpmn:documentation>Proses selesai. Data pembimbing telah diinput ke Lentera oleh Admin. Tidak ada notifikasi otomatis ke mahasiswa.</bpmn:documentation>
      <bpmn:incoming>Flow_16</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="Flow_01" sourceRef="StartEvent_MencapaiSKS" targetRef="Task_MenemuiPA" />
    <bpmn:sequenceFlow id="Flow_04" name="Tidak" sourceRef="Gateway_SKSMemenuhi" targetRef="EndEvent_DitolakSKS">
      <bpmn:documentation>Mahasiswa belum memenuhi syarat 130 SKS.</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_02" sourceRef="Task_MenemuiPA" targetRef="Task_VerifikasiKHSManual" />
    <bpmn:sequenceFlow id="Flow_03" sourceRef="Task_VerifikasiKHSManual" targetRef="Gateway_SKSMemenuhi" />
    <bpmn:sequenceFlow id="Flow_05" name="Ya" sourceRef="Gateway_SKSMemenuhi" targetRef="Task_HubungiPembimbing">
      <bpmn:documentation>Mahasiswa telah memenuhi 130 SKS, lanjut pencarian pembimbing.</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_10" sourceRef="Task_CariPembimbingLain" targetRef="Task_HubungiPembimbing" />
    <bpmn:sequenceFlow id="Flow_13" name="Tidak (Penuh)" sourceRef="Gateway_KuotaTersedia" targetRef="Task_CariPembimbingLain">
      <bpmn:documentation>Kuota penuh. Mahasiswa kembali mencari pembimbing lain — loop yang membuang waktu.</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_06" sourceRef="Task_HubungiPembimbing" targetRef="Task_PembimbingPertimbangkan" />
    <bpmn:sequenceFlow id="Flow_07" sourceRef="Task_PembimbingPertimbangkan" targetRef="Gateway_PembimbingSetuju" />
    <bpmn:sequenceFlow id="Flow_08" name="Ya" sourceRef="Gateway_PembimbingSetuju" targetRef="Task_CekKuotaManual">
      <bpmn:documentation>Dosen menyatakan setuju via pesan atau verbal.</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_09" name="Tidak" sourceRef="Gateway_PembimbingSetuju" targetRef="Task_CariPembimbingLain">
      <bpmn:documentation>Dosen menolak atau tidak merespons. Mahasiswa mencari pembimbing lain.</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_11" sourceRef="Task_CekKuotaManual" targetRef="Gateway_KuotaTersedia" />
    <bpmn:sequenceFlow id="Flow_12" name="Ya" sourceRef="Gateway_KuotaTersedia" targetRef="Task_IsiFormulirFisik">
      <bpmn:documentation>Kuota dosen masih tersedia (belum 10 mahasiswa).</bpmn:documentation>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_14" sourceRef="Task_IsiFormulirFisik" targetRef="Task_SerahkanFormulir" />
    <bpmn:sequenceFlow id="Flow_15" sourceRef="Task_SerahkanFormulir" targetRef="Task_VerifikasiDokumen" />
    <bpmn:sequenceFlow id="Flow_16a" sourceRef="Task_VerifikasiDokumen" targetRef="Task_InputDataLentera" />
    <bpmn:sequenceFlow id="Flow_16" sourceRef="Task_InputDataLentera" targetRef="EndEvent_PembimbingTerdaftar" />
    <bpmn:dataObjectReference id="DataRef_KHS" name="KHS (Kartu Hasil Studi)" dataObjectRef="DataObject_KHS">
      <bpmn:documentation>Rekap nilai dan SKS mahasiswa dari UNISIS desktop. Digunakan PA untuk verifikasi manual pencapaian 130 SKS. Rentan keterlambatan karena harus dibuka dari aplikasi desktop terpisah.</bpmn:documentation>
    </bpmn:dataObjectReference>
    <bpmn:dataObject id="DataObject_KHS" />
    <bpmn:dataObjectReference id="DataRef_FormulirFisik" name="Formulir Pembimbing TA (Fisik)" dataObjectRef="DataObject_FormulirFisik">
      <bpmn:documentation>Formulir kertas berisi data diri, NIM, judul TA, dan nama pembimbing. Satu-satunya bukti pengajuan sebelum diinput ke Lentera. Rentan hilang dan salah isi.</bpmn:documentation>
    </bpmn:dataObjectReference>
    <bpmn:dataObject id="DataObject_FormulirFisik" />
  </bpmn:process>
  <bpmndi:BPMNDiagram id="BPMNDiagram_AsIs">
    <bpmndi:BPMNPlane id="BPMNPlane_AsIs" bpmnElement="AsIs_Pemilihan_Pembimbing_TA">
      <bpmndi:BPMNShape id="Shape_Pool" bpmnElement="Pool_Proses" isHorizontal="true">
        <dc:Bounds x="160" y="150" width="1588" height="820" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_AdminProdi" bpmnElement="Lane_AdminProdi" isHorizontal="true">
        <dc:Bounds x="190" y="705" width="1558" height="265" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_DosenPembimbing" bpmnElement="Lane_DosenPembimbing" isHorizontal="true">
        <dc:Bounds x="190" y="520" width="1558" height="185" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_DosenPA" bpmnElement="Lane_DosenPA" isHorizontal="true">
        <dc:Bounds x="190" y="335" width="1558" height="185" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Lane_Mahasiswa" bpmnElement="Lane_Mahasiswa" isHorizontal="true">
        <dc:Bounds x="190" y="150" width="1558" height="185" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_StartEvent" bpmnElement="StartEvent_MencapaiSKS">
        <dc:Bounds x="252" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="243" y="265" width="56" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_EndEvent_DitolakSKS" bpmnElement="EndEvent_DitolakSKS">
        <dc:Bounds x="1562" y="222" width="36" height="36" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1535" y="172" width="90" height="40" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_MenemuiPA" bpmnElement="Task_MenemuiPA">
        <dc:Bounds x="340" y="200" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_VerifikasiKHS" bpmnElement="Task_VerifikasiKHSManual">
        <dc:Bounds x="340" y="385" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GW_SKS" bpmnElement="Gateway_SKSMemenuhi" isMarkerVisible="true">
        <dc:Bounds x="545" y="400" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="541" y="457" width="59" height="14" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_HubungiPembimbing" bpmnElement="Task_HubungiPembimbing">
        <dc:Bounds x="660" y="200" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_PembimbingPertimbangkan" bpmnElement="Task_PembimbingPertimbangkan">
        <dc:Bounds x="660" y="570" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GW_Setuju" bpmnElement="Gateway_PembimbingSetuju" isMarkerVisible="true">
        <dc:Bounds x="855" y="585" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="915" y="606" width="62" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CariPembimbingLain" bpmnElement="Task_CariPembimbingLain">
        <dc:Bounds x="880" y="200" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_CekKuota" bpmnElement="Task_CekKuotaManual">
        <dc:Bounds x="1020" y="755" width="120" height="80" />
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_GW_Kuota" bpmnElement="Gateway_KuotaTersedia" isMarkerVisible="true">
        <dc:Bounds x="1175" y="770" width="50" height="50" />
        <bpmndi:BPMNLabel>
          <dc:Bounds x="1235" y="781" width="48" height="27" />
        </bpmndi:BPMNLabel>
      </bpmndi:BPMNShape>
      <bpmndi:BPMNShape id="Shape_Task_IsiFormulirFisik" bpmnElement="Task_IsiFormulirFisik">
