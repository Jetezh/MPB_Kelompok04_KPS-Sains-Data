<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:ns1="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:open-bpmn="http://open-bpmn.org/XMLSchema" targetNamespace="http://fik.prodi.bpm/pemilihan-pembimbing-to-be" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:collaboration id="Pemilihan_Pembimbing_TA">
    <bpmn:participant id="Pool_ToBe" name="Proses Pemilihan Dosen Pembimbing TA (TO-BE)" processRef="Process_ToBe">
      <bpmn:documentation>Proses pemilihan dosen pembimbing TA pada kondisi target (TO-BE). Menggunakan arsitektur event-driven berbasis middleware API untuk menjembatani data UNISIS ke web. Tiga inovasi utama: (1) deteksi otomatis 130 SKS, (2) Advisor Marketplace dengan kuota real-time, (3) eskalasi otomatis berbasis timer SLA.</bpmn:documentation>
    </bpmn:participant>
    <bpmn:textAnnotation id="TextAnn_AutoTrigger">
      <bpmn:documentation id="documentation_PRv8Gg" />
      <bpmn:text>Middleware otomatis query UNISIS, tidak perlu mahasiswa datang ke PA.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnn_AutoLock">
      <bpmn:documentation id="documentation_oD2n1Q" />
      <bpmn:text>Auto-lock kuota ke-10. Slot otomatis bebas saat mahasiswa lulus (Graduation Sync).</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Ann_Trigger" sourceRef="TextAnn_AutoTrigger" targetRef="StartEvent_SistemDeteksiSKS" />
    <bpmn:association id="Assoc_Ann_AutoLock" sourceRef="TextAnn_AutoLock" targetRef="Task_CekKuotaOtomatis" />
  </bpmn:collaboration>
  <bpmn:process id="Process_ToBe" name="Pemilihan Pembimbing TA - TO-BE (Automated)" processType="Private" isExecutable="true" ns1:historyTimeToLive="30">
    <bpmn:laneSet id="LaneSet_ToBe">
      <bpmn:lane id="Lane_Sistem" name="SISTEM (Automated Service)">
        <bpmn:documentation>Lane khusus untuk Service Tasks yang dieksekusi secara otomatis oleh sistem tanpa intervensi manusia. Mencakup sinkronisasi data, pengiriman notifikasi, pengecekan kuota, dan pembaruan database.</bpmn:documentation>
        <bpmn:flowNodeRef>StartEvent_SistemDeteksiSKS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_KirimNotifPA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_KirimRequestKePembimbing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CekKuotaOtomatis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_NotifPenolakanPA</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_EskalasiKeProdi</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_AutoUpdateDatabase</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_SelesaiOtomatis</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_KirimKonfirmasiSemua</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DosenPA_ToBe" name="Dosen PA (Penasehat Akademik)">
        <bpmn:documentation>Dosen PA menerima notifikasi otomatis dari sistem dan dapat mereview status mahasiswanya di dashboard kapan saja. Menjadwalkan konseling digital tanpa perlu rapat koordinasi terlebih dahulu.</bpmn:documentation>
        <bpmn:flowNodeRef>Task_PAValidasiDigital</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_ValidasiPABerhasil</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EndEvent_MahasiswaTidakLayak</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Mahasiswa_ToBe" name="Mahasiswa">
        <bpmn:documentation>Mahasiswa menerima notifikasi peringatan dan dapat merespons secara digital melalui portal akademik, mengkonfirmasi status studi mereka tanpa harus datang ke kampus.</bpmn:documentation>
        <bpmn:flowNodeRef>Task_BrowseAdvisorMarketplace</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_SubmitRequestDigital</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Task_CariPembimbingLain_ToBe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_RetryPembimbing</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Pembimbing_ToBe" name="Dosen Pembimbing TA">
        <bpmn:documentation>Dosen pembimbing menerima notifikasi request digital dan dapat memberikan approve atau reject melalui sistem. Terikat SLA 3 hari respons.</bpmn:documentation>
        <bpmn:flowNodeRef>Task_PembimbingReviewRequest</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Gateway_PembimbingApprove</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>Event_0p0ned1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Prodi" name="Koordinator Prodi (Eskalasi)">
        <bpmn:documentation>Koordinator Prodi menangani eskalasi jika dosen tidak merespons dalam SLA atau ketika tidak ada pembimbing alternatif yang tersedia secara otomatis.</bpmn:documentation>
        <bpmn:flowNodeRef>Task_ProdiRoutingManual</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="StartEvent_SistemDeteksiSKS" name="Sistem Deteksi&#10;Mahasiswa ≥ 130 SKS&#10;(via Middleware UNISIS)" ns1:formRef="form_start_pembimbing_ta" ns1:formRefBinding="latest">
      <bpmn:documentation>Trigger otomatis: middleware API melakukan query ke UNISIS secara periodik dan mendeteksi mahasiswa yang telah mencapai 130 SKS dengan status UKT lunas. Menggantikan proses manual mahasiswa mendatangi Dosen PA.</bpmn:documentation>
      <bpmn:outgoing>Flow_T01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="Task_KirimNotifPA" name="Kirim Notifikasi&#10;Otomatis ke PA&#10;(Email Institusional)">
      <bpmn:documentation>Sistem mengirim notifikasi email institusional otomatis ke Dosen PA yang berisi informasi mahasiswa layak TA beserta ringkasan data akademiknya. Tidak memerlukan tindakan manual dari siapapun.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">// Init retry counter
execution.setVariable('retryPembimbing', 0);

// Variabel diambil dari form Start Event

// Inisialisasi data pengajuan Tugas Akhir mahasiswa

var nama = execution.getVariable('namaMahasiswa');
var nim = execution.getVariable('nimMahasiswa');
var sks = execution.getVariable('totalSKS');

JSON.stringify({
  "embeds": [{
    "title": "📢 [NOTIFIKASI OPERASIONAL] ⏱️ PROSES 2 -&gt; Deteksi Eligibilitas TA",
    "description": "Sistem mendeteksi mahasiswa telah menembus batas syarat SKS. Email otomatis berhasil dikirim ke Penasehat Akademik.",
    "color": 11039861,
    "fields": [
      { "name": "Kandidat", "value": nama + " (" + nim + ")", "inline": true },
      { "name": "SKS Terdata", "value": sks + " SKS", "inline": true },
      { "name": "Status Verifikasi", "value": "Menunggu Validasi KHS oleh Dosen PA", "inline": false }
    ],
    "footer": { "text": "Source Gateway: Middleware UNISIS Engine" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_T01</bpmn:incoming>
      <bpmn:outgoing>Flow_T02</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOut_NotifPA">
        <bpmn:targetRef>DataRef_NotifEligible</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_PAValidasiDigital" name="PA Validasi KHS&#10;Secara Digital&#10;(One-Click di Dashboard)" ns1:formRef="form_pa_validasi_khs" ns1:formRefBinding="latest" ns1:candidateGroups="Dosen">
      <bpmn:documentation>Dosen PA melakukan validasi digital one-click di dashboard terintegrasi. Data KHS sudah ditampilkan oleh sistem sehingga PA tidak perlu membuka UNISIS secara terpisah.</bpmn:documentation>
      <bpmn:incoming>Flow_T02</bpmn:incoming>
      <bpmn:outgoing>Flow_T03</bpmn:outgoing>
      <bpmn:property id="Property_17atqav" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_0pboqkt">
        <bpmn:sourceRef>DataRef_NotifEligible</bpmn:sourceRef>
        <bpmn:targetRef>Property_17atqav</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="Task_BrowseAdvisorMarketplace" name="Browse Advisor&#10;Marketplace&#10;(Lihat Slot Real-Time)" ns1:formRef="form_browse_marketplace" ns1:formRefBinding="latest" ns1:candidateGroups="Mahasiswa">
      <bpmn:documentation>Mahasiswa mengakses Advisor Marketplace — antarmuka web yang menampilkan daftar pembimbing tersedia beserta spesialisasi, rekam jejak RPS dari SIMPEL, dan sisa slot kuota secara real-time.</bpmn:documentation>
      <bpmn:incoming>Flow_T06</bpmn:incoming>
      <bpmn:outgoing>Flow_T07</bpmn:outgoing>
      <bpmn:property id="Property_13sm294" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1mgzeqz">
        <bpmn:sourceRef>DataRef_AdvisorMarketplace</bpmn:sourceRef>
        <bpmn:targetRef>Property_13sm294</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="Task_SubmitRequestDigital" name="Submit Request&#10;Digital ke Calon&#10;Pembimbing" ns1:formRef="form_submit_request_ta" ns1:formRefBinding="latest" ns1:candidateGroups="Mahasiswa">
      <bpmn:documentation>Mahasiswa mengirim request digital resmi ke calon pembimbing yang dipilih. Request tercatat dengan timestamp dan menjadi bagian dari audit trail resmi — menggantikan japri/lisan.</bpmn:documentation>
      <bpmn:incoming>Flow_T07</bpmn:incoming>
      <bpmn:incoming>Flow_T11</bpmn:incoming>
      <bpmn:outgoing>Flow_T08</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOut_Request">
        <bpmn:targetRef>DataRef_DigitalRequest</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:serviceTask id="Task_KirimRequestKePembimbing" name="Kirim Notifikasi&#10;Request ke Pembimbing&#10;(dengan Deadline SLA)">
      <bpmn:documentation id="documentation_x0Ozyw" />
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var nama = execution.getVariable('namaMahasiswa');
var nim = execution.getVariable('nimMahasiswa');
var dosen = execution.getVariable('dosenUsulan');

JSON.stringify({
  "embeds": [{
    "title": "📢 [NOTIFIKASI OPERASIONAL] ⏱️ PROSES 2 -&gt; Pengiriman Berkas ke Calon Pembimbing",
    "description": "Notifikasi draf proposal masuk ke portal dosen pembimbing. Arloji pengawasan batas waktu (SLA) resmi dinyalakan.",
    "color": 10181046,
    "fields": [
      { "name": "Pengaju", "value": nama + " (" + nim + ")", "inline": true },
      { "name": "Calon Pembimbing", "value": dosen, "inline": true },
      { "name": "Batas Waktu Respon", "value": "⏳ 3 Hari Kerja (Timer SLA Active)", "inline": false }
    ],
    "footer": { "text": "Camunda Core Event: Boundary Timer Activation" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_T08</bpmn:incoming>
      <bpmn:outgoing>Flow_T09</bpmn:outgoing>
      <bpmn:property id="Property_1dancoh" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_18jmikw">
        <bpmn:sourceRef>DataRef_DigitalRequest</bpmn:sourceRef>
        <bpmn:targetRef>Property_1dancoh</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:serviceTask>
    <bpmn:dataObjectReference id="DataRef_NotifEligible" name="Notifikasi Eligibilitas (130 SKS + UKT Lunas)" dataObjectRef="DataObject_NotifEligible">
      <bpmn:documentation>Notifikasi otomatis dari middleware ke Dosen PA saat mahasiswa memenuhi syarat 130 SKS dan UKT lunas. Menggantikan kunjungan fisik mahasiswa ke PA.</bpmn:documentation>
    </bpmn:dataObjectReference>
    <bpmn:dataObject id="DataObject_NotifEligible">
      <bpmn:documentation id="documentation_iyAhtg" />
    </bpmn:dataObject>
    <bpmn:serviceTask id="Task_CekKuotaOtomatis" name="Cek Kuota Pembimbing&#10;Real-Time (Auto-Lock&#10;jika Penuh)">
      <bpmn:documentation>Service Task otomatis yang mengquery database kuota pembimbing secara real-time. Pembimbing dengan kuota penuh (10 mahasiswa) otomatis di-lock dari daftar pilihan di Advisor Marketplace.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var nama = execution.getVariable('namaMahasiswa');
var dosen = execution.getVariable('dosenUsulan');

// Simulasi kuota bimbingan dosen di sistem database
var sisaKuota = 2; 
execution.setVariable('slotSisaDosen', sisaKuota);

JSON.stringify({
  "embeds": [{
    "title": "🤖 [LOG SISTEM OTOMATIS] 📋 PROSES 2 -&gt; Live Quota Verification",
    "description": "Mesin melakukan pengecekan matriks beban bimbingan dosen pada repositori fakultas.",
    "color": 7616946,
    "fields": [
      { "name": "Dosen Target", "value": dosen, "inline": true },
      { "name": "Sisa Kuota Slot", "value": sisaKuota + " Mahasiswa Lagi", "inline": true },
      { "name": "Aksi Sistem", "value": "Membuka gerbang 'Submit Request Digital' ke mahasiswa.", "inline": false }
    ],
    "footer": { "text": "Database Component: Auto-Lock Advisor Engine" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_T04</bpmn:incoming>
      <bpmn:incoming>Flow_RetryOk</bpmn:incoming>
      <bpmn:outgoing>Flow_T06</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOut_Marketplace">
        <bpmn:targetRef>DataRef_AdvisorMarketplace</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:dataObjectReference id="DataRef_DigitalRequest" name="Request Pembimbing Digital (Formal)" dataObjectRef="DataObject_DigitalRequest">
      <bpmn:documentation>Request pengajuan pembimbing yang dikirim secara digital oleh mahasiswa. Tercatat dengan timestamp sebagai audit trail resmi — menggantikan japri/lisan.</bpmn:documentation>
    </bpmn:dataObjectReference>
    <bpmn:dataObject id="DataObject_DigitalRequest">
      <bpmn:documentation id="documentation_SqEwAg" />
    </bpmn:dataObject>
    <bpmn:sequenceFlow id="Flow_T01" sourceRef="StartEvent_SistemDeteksiSKS" targetRef="Task_KirimNotifPA">
      <bpmn:documentation id="documentation_PX0zgA" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T02" sourceRef="Task_KirimNotifPA" targetRef="Task_PAValidasiDigital">
      <bpmn:documentation id="documentation_on97uA" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T03" sourceRef="Task_PAValidasiDigital" targetRef="Gateway_ValidasiPABerhasil">
      <bpmn:documentation id="documentation_Z37s5A" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T04" name="Ya, Layak" sourceRef="Gateway_ValidasiPABerhasil" targetRef="Task_CekKuotaOtomatis">
      <bpmn:documentation id="documentation_R6uvDg" />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isKHSValid == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T05" name="Tidak, Tidak Layak" sourceRef="Gateway_ValidasiPABerhasil" targetRef="Task_NotifPenolakanPA">
      <bpmn:documentation id="documentation_GKW0aQ" />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isKHSValid == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T06" sourceRef="Task_CekKuotaOtomatis" targetRef="Task_BrowseAdvisorMarketplace">
      <bpmn:documentation id="documentation_7pQoSQ" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T07" sourceRef="Task_BrowseAdvisorMarketplace" targetRef="Task_SubmitRequestDigital">
      <bpmn:documentation id="documentation_szEBlQ" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T11_helper" sourceRef="Task_CariPembimbingLain_ToBe" targetRef="GW_RetryPembimbing">
      <bpmn:documentation id="documentation_s0jmtw" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T08" sourceRef="Task_SubmitRequestDigital" targetRef="Task_KirimRequestKePembimbing">
      <bpmn:documentation id="documentation_ns8YLQ" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T09" sourceRef="Task_KirimRequestKePembimbing" targetRef="Task_PembimbingReviewRequest">
      <bpmn:documentation id="documentation_JmJr7A" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T11" name="Tidak, Reject" sourceRef="Gateway_PembimbingApprove" targetRef="Task_CariPembimbingLain_ToBe">
      <bpmn:documentation id="documentation_Mm37fA" />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isApprovedPembimbing == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RetryOk" name="Ya (&#60; 3x)" sourceRef="GW_RetryPembimbing" targetRef="Task_CekKuotaOtomatis">
      <bpmn:documentation id="documentation_70QvDw" />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${retryPembimbing &lt; 3}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T05b" sourceRef="Task_NotifPenolakanPA" targetRef="EndEvent_MahasiswaTidakLayak">
      <bpmn:documentation id="documentation_iucRbQ" />
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="Task_NotifPenolakanPA" name="Kirim Notifikasi&#10;Penolakan ke&#10;Mahasiswa">
      <bpmn:documentation>Sistem mengirim notifikasi penolakan ke mahasiswa beserta alasan (SKS kurang/UKT belum lunas). Mahasiswa tidak perlu menunggu tanpa kejelasan.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var nama = execution.getVariable('namaMahasiswa');
var nim = execution.getVariable('nimMahasiswa');
var sks = execution.getVariable('totalSKS');

JSON.stringify({
  "embeds": [{
    "title": "❌ [🔔 NOTIFIKASI]📳 Pengajuan TA Ditolak",
    "description": "Dosen PA menilai mahasiswa belum memenuhi syarat untuk mengajukan Tugas Akhir.",
    "color": 15158332,
    "fields": [
      { "name": "Mahasiswa", "value": nama + " (" + nim + ")", "inline": true },
      { "name": "SKS Saat Ini", "value": sks + " SKS", "inline": true },
      { "name": "Status", "value": "Tidak Layak — Hubungi PA untuk detail", "inline": false }
    ],
    "footer": { "text": "Automated Rejection Notification" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_T05</bpmn:incoming>
      <bpmn:outgoing>Flow_T05b</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="Gateway_ValidasiPABerhasil" name="Validasi PA&#10;Berhasil?">
      <bpmn:documentation>Keputusan berdasarkan hasil validasi digital PA. Ya: mahasiswa layak dan sistem melepas akses ke Advisor Marketplace. Tidak/Error: sistem mengirim notifikasi penolakan ke mahasiswa beserta alasan.</bpmn:documentation>
      <bpmn:incoming>Flow_T03</bpmn:incoming>
      <bpmn:outgoing>Flow_T04</bpmn:outgoing>
      <bpmn:outgoing>Flow_T05</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="EndEvent_MahasiswaTidakLayak" name="Proses Dihentikan&#10;(Mahasiswa Tidak&#10;Memenuhi Syarat)">
      <bpmn:documentation>Proses dihentikan karena mahasiswa tidak memenuhi syarat (SKS kurang atau UKT belum lunas). Sistem mengirim notifikasi ke mahasiswa beserta informasi kekurangannya.</bpmn:documentation>
      <bpmn:incoming>Flow_T05b</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:dataObjectReference id="DataRef_AdvisorMarketplace" name="Data Advisor Marketplace (Kuota Real-Time)" dataObjectRef="DataObject_AdvisorMarketplace">
      <bpmn:documentation>Data ketersediaan pembimbing secara real-time: nama, spesialisasi, sisa slot kuota. Ditampilkan di dashboard mahasiswa — menggantikan japri/lisan.</bpmn:documentation>
    </bpmn:dataObjectReference>
    <bpmn:dataObject id="DataObject_AdvisorMarketplace">
      <bpmn:documentation id="documentation_fQp7pQ" />
    </bpmn:dataObject>
    <bpmn:userTask id="Task_CariPembimbingLain_ToBe" name="Mahasiswa Pilih&#10;Pembimbing Lain&#10;di Marketplace" ns1:formRef="form_cari_pembimbing_lain" ns1:formRefBinding="latest" ns1:candidateGroups="Mahasiswa">
      <bpmn:documentation>Mahasiswa memilih pembimbing alternatif di Advisor Marketplace. Berbeda dengan AS-IS, mahasiswa langsung melihat daftar pembimbing yang tersedia (sudah difilter kuota) sehingga tidak perlu japri satu per satu.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:executionListener event="end">
          <ns1:script scriptFormat="javascript">var c = execution.getVariable('retryPembimbing') || 0;
c = c + 1;
execution.setVariable('retryPembimbing', c);</ns1:script>
        </ns1:executionListener>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_T11_helper</bpmn:incoming>
      <bpmn:outgoing>Flow_T11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="Task_PembimbingReviewRequest" name="Pembimbing Review&#10;dan Approve/Reject&#10;Request Mahasiswa" ns1:formRef="form_pembimbing_review" ns1:formRefBinding="latest" ns1:candidateGroups="Dosen">
      <bpmn:documentation>Dosen pembimbing menerima notifikasi request dan dapat mereview detail topik TA mahasiswa, lalu memberikan keputusan approve atau reject melalui antarmuka sistem dalam SLA 3 hari.</bpmn:documentation>
      <bpmn:incoming>Flow_T09</bpmn:incoming>
      <bpmn:outgoing>Flow_T15</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:boundaryEvent id="Event_0p0ned1" attachedToRef="Task_PembimbingReviewRequest">
      <bpmn:documentation id="documentation_xYANhw" />
      <bpmn:outgoing>Flow_0r9un3u</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_04gqj85">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT1M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:sequenceFlow id="Flow_T15" sourceRef="Task_PembimbingReviewRequest" targetRef="Gateway_PembimbingApprove">
      <bpmn:documentation id="documentation_xsoTTw" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T16a" name="Ya, Approve" sourceRef="Gateway_PembimbingApprove" targetRef="Task_AutoUpdateDatabase">
      <bpmn:documentation id="documentation_qJrR6A" />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isApprovedPembimbing == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_0r9un3u" sourceRef="Event_0p0ned1" targetRef="Task_EskalasiKeProdi">
      <bpmn:documentation id="documentation_sTA09g" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_RetryGagal" name="Gagal (&#62;= 3x)" sourceRef="GW_RetryPembimbing" targetRef="Task_EskalasiKeProdi">
      <bpmn:documentation id="documentation_ddlzpw" />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${retryPembimbing &gt;= 3}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="GW_RetryPembimbing" name="Retry&#10;Masih Bisa?">
      <bpmn:documentation id="documentation_jkM2lg" />
      <bpmn:incoming>Flow_T11_helper</bpmn:incoming>
      <bpmn:outgoing>Flow_RetryOk</bpmn:outgoing>
      <bpmn:outgoing>Flow_RetryGagal</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_EskalasiKeProdi" name="Eskalasi Otomatis&#10;ke Koordinator Prodi&#10;(Notifikasi Darurat)">
      <bpmn:documentation>Sistem mengirim notifikasi eskalasi otomatis ke Koordinator Prodi beserta informasi mahasiswa dan dosen yang tidak merespons, sehingga Prodi dapat melakukan routing manual ke pembimbing alternatif.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var nama = execution.getVariable('namaMahasiswa');
var nim = execution.getVariable('nimMahasiswa');
var dosen = execution.getVariable('dosenUsulan');
var judul = execution.getVariable('judulTA');

JSON.stringify({
  "embeds": [{
    "title": "⚠️ [🔔 NOTIFIKASI ESKALASI] 📨 PROSES 2 -&gt; Batas Waktu SLA Terlampaui",
    "description": "Sistem mendeteksi adanya keterlambatan respon dari pihak dosen pembimbing. Hak penunjukan alternatif resmi diambil alih oleh Program Studi.",
    "color": 12597547, // Warna Merah Peringatan Kritis
    "fields": [
      { "name": "Mahasiswa", "value": nama + " (" + nim + ")", "inline": true },
      { "name": "Judul Proposal TA", "value": "" + judul, "inline": false },
      { "name": "Dosen Target Awal", "value": dosen, "inline": true },
      { "name": "Status Alur Kerja", "value": " Dialihkan otomatis ke meja Koordinator Prodi (`g4kps`)", "inline": false }
    ],
    "footer": { "text": "SLA Monitor Component | Interrupting Boundary Event" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_0r9un3u</bpmn:incoming>
      <bpmn:incoming>Flow_RetryGagal</bpmn:incoming>
      <bpmn:outgoing>Flow_T17</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="Task_ProdiRoutingManual" name="Koprodi Assign&#10;Pembimbing Alternatif&#10;secara Manual" ns1:formRef="form_prodi_routing" ns1:formRefBinding="latest" ns1:candidateGroups="KPS">
      <bpmn:documentation>Koordinator Prodi secara manual menugaskan pembimbing alternatif berdasarkan eskalasi dari sistem, memastikan tidak ada mahasiswa yang terlantar tanpa pembimbing.</bpmn:documentation>
      <bpmn:incoming>Flow_T17</bpmn:incoming>
      <bpmn:outgoing>Flow_T14</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:sequenceFlow id="Flow_T17" sourceRef="Task_EskalasiKeProdi" targetRef="Task_ProdiRoutingManual">
      <bpmn:documentation id="documentation_xMR4Sw" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_T14" sourceRef="Task_ProdiRoutingManual" targetRef="Task_AutoUpdateDatabase">
      <bpmn:documentation id="documentation_2aqh0Q" />
    </bpmn:sequenceFlow>
    <bpmn:exclusiveGateway id="Gateway_PembimbingApprove" name="Pembimbing&#10;Approve?">
      <bpmn:documentation>Keputusan pembimbing. Approve: sistem langsung memproses pembaruan database. Reject/Tidak Merespons: mahasiswa diarahkan untuk memilih pembimbing alternatif di Marketplace.</bpmn:documentation>
      <bpmn:incoming>Flow_T15</bpmn:incoming>
      <bpmn:outgoing>Flow_T16a</bpmn:outgoing>
      <bpmn:outgoing>Flow_T11</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="Task_AutoUpdateDatabase" name="Auto-Update Database&#10;Kurangi Kuota Pembimbing&#10;+1 Mahasiswa Terdaftar">
      <bpmn:documentation>Service Task yang secara otomatis memperbarui database: kuota dosen berkurang 1, status mahasiswa berubah menjadi "Terdaftar Pembimbing", dan record tersimpan di Lentera dengan audit trail lengkap.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var dosen = execution.getVariable('dosenUsulan');
var slotAwal = execution.getVariable('slotSisaDosen');
var slotBaru = slotAwal - 1;

execution.setVariable('slotSisaDosen', slotBaru);

JSON.stringify({
  "embeds": [{
    "title": "🤖 [LOG SISTEM OTOMATIS] 📋 PROSES 2 -&gt; Modifikasi Partisi Data Kuota",
    "description": "Persetujuan terdeteksi. Sistem melakukan mutasi pengurangan kapasitas bimbingan dosen di basis data.",
    "color": 7616946,
    "fields": [
      { "name": "Nama Dosen", "value": dosen, "inline": true },
      { "name": "Kapasitas Baru", "value": slotBaru + " Slot Tersisa", "inline": true }
    ],
    "footer": { "text": "Data Writer Component: Update Transaction Success" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_T16a</bpmn:incoming>
      <bpmn:incoming>Flow_T14</bpmn:incoming>
      <bpmn:outgoing>Flow_T18</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EndEvent_SelesaiOtomatis" name="Pembimbing TA&#10;Resmi Terdaftar&#10;(Audit Trail Digital)">
      <bpmn:documentation>Proses selesai dengan sempurna. Pembimbing TA terdaftar secara digital di Lentera dengan audit trail lengkap (timestamp, identitas aktor, riwayat keputusan). Semua pihak menerima konfirmasi otomatis.</bpmn:documentation>
      <bpmn:incoming>Flow_T16</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="Task_KirimKonfirmasiSemua" name="Kirim Konfirmasi&#10;ke Mahasiswa, PA,&#10;Prodi, dan Pembimbing">
      <bpmn:documentation>Sistem mengirim konfirmasi resmi ke semua pihak: mahasiswa, Dosen PA, Dosen Pembimbing, dan Koordinator Prodi. Menggantikan notifikasi manual yang sering terlambat atau tidak tersampaikan.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var nama = execution.getVariable('namaMahasiswa');
var nim = execution.getVariable('nimMahasiswa');
var dosen = execution.getVariable('dosenUsulan');

JSON.stringify({
  "embeds": [{
    "title": "📢 [NOTIFIKASI OPERASIONAL] ⏱️ PROSES 2 -&gt; Pengesahan Pembimbing TA Selesai",
    "description": "Sukses! Surat keputusan digital berhasil diterbitkan dan disiarkan ke seluruh aktor pemangku kepentingan.",
    "color": 3066993,
    "fields": [
      { "name": "Mahasiswa Bimbingan", "value": nama + " (" + nim + ")", "inline": false },
      { "name": "Dosen Pembimbing Sah", "value": dosen, "inline": true },
      { "name": "Arsip Digital", "value": "✅ Terpahat di Smart Contract Audit Trail", "inline": true }
    ],
    "footer": { "text": "End-to-End Execution Complete | Tenant 4" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>Flow_T18</bpmn:incoming>
      <bpmn:outgoing>Flow_T16</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOut_AuditTrail">
        <bpmn:targetRef>DataRef_AuditTrail</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:dataObjectReference id="DataRef_AuditTrail" name="Audit Trail Digital + Smart Contract" dataObjectRef="DataObject_AuditTrail">
      <bpmn:documentation>Rekam jejak lengkap seluruh transaksi tersimpan permanen. Setelah pembimbing disetujui, supervisi diformalkan sebagai Smart Contract blockchain yang immutable.</bpmn:documentation>
    </bpmn:dataObjectReference>
    <bpmn:dataObject id="DataObject_AuditTrail">
      <bpmn:documentation id="documentation_Cteg5Q" />
    </bpmn:dataObject>
