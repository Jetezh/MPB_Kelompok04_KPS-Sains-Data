            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var mk = execution.getVariable('mataKuliahRPS');
var dosen = execution.getVariable('dosenKoor');

JSON.stringify({
  "embeds": [{
    "title": "📢 [NOTIFIKASI OPERASIONAL] 📚 PROSES 4 -&gt; Broadcast Pengingat Batas Waktu",
