    <bpmn:sequenceFlow id="F_TB_RPS_back" sourceRef="T_EskalasiKorprodi" targetRef="T_DosenInputSIMPEL" />
    <bpmn:sequenceFlow id="F_TB_RPS_l1ya" name="Approve" sourceRef="GW_L1_ToBe" targetRef="T_AutoRoute_L2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isL1Approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_08" sourceRef="T_AutoRoute_L2" targetRef="T_GKMReviewL2" />
    <bpmn:sequenceFlow id="F_TB_RPS_l2ya" name="Approve" sourceRef="GW_L2_ToBe" targetRef="T_AutoRoute_L3">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isL2Approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_10" sourceRef="T_AutoRoute_L3" targetRef="T_WadekApproveL3" />
    <bpmn:sequenceFlow id="F_TB_RPS_06" sourceRef="T_AutoRoute_L1" targetRef="T_KorprodiReviewL1" />
    <bpmn:sequenceFlow id="F_TB_RPS_l1" sourceRef="T_KorprodiReviewL1" targetRef="GW_L1_ToBe" />
    <bpmn:sequenceFlow id="F_TB_RPS_l1tidak" name="Revisi" sourceRef="GW_L1_ToBe" targetRef="T_KorprodiInputRevisiL1">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isL1Approved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_rev1" sourceRef="T_KorprodiInputRevisiL1" targetRef="T_DosenRevisiToBe" />
    <bpmn:sequenceFlow id="F_TB_RPS_revdosen" sourceRef="T_DosenRevisiToBe" targetRef="T_DosenInputSIMPEL" />
    <bpmn:sequenceFlow id="F_TB_RPS_dosen_in" sourceRef="T_DosenInputSIMPEL" targetRef="T_DosenSubmit" />
    <bpmn:sequenceFlow id="F_TB_RPS_05" sourceRef="T_DosenSubmit" targetRef="T_AutoRoute_L1" />
    <bpmn:sequenceFlow id="F_TB_RPS_rev2" sourceRef="T_GKMInputRevisiL2" targetRef="T_DosenRevisiToBe" />
    <bpmn:sequenceFlow id="F_TB_RPS_rev3" name="Revisi" sourceRef="GW_L3_ToBe" targetRef="T_DosenRevisiToBe">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isL3Approved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_l2" sourceRef="T_GKMReviewL2" targetRef="GW_L2_ToBe" />
    <bpmn:sequenceFlow id="F_TB_RPS_l2tidak" name="Revisi" sourceRef="GW_L2_ToBe" targetRef="T_GKMInputRevisiL2">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isL2Approved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_l3" sourceRef="T_WadekApproveL3" targetRef="GW_L3_ToBe" />
    <bpmn:sequenceFlow id="F_TB_RPS_end" sourceRef="T_PublishRPS" targetRef="EE_RPSPublished" />
    <bpmn:sequenceFlow id="F_TB_RPS_12" sourceRef="T_GeneratePDFFinal" targetRef="T_PublishRPS" />
    <bpmn:sequenceFlow id="F_TB_RPS_l3ya" name="Approve" sourceRef="GW_L3_ToBe" targetRef="T_PublishRPS">
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isL3Approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_146yieq" sourceRef="T_PublishRPS" targetRef="T_GeneratePDFFinal" />
