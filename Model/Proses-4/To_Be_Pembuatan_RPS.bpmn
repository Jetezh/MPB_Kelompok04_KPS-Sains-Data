      <bpmn:outgoing>Flow_0jfv94h</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="T_DosenRevisiToBe" name="Dosen Revisi RPS&#10;Berdasarkan Notif&#10;Catatan di SIMPEL" ns1:candidateGroups="Dosen" ns1:formRef="form_dosen_revisi_rps" ns1:formRefBinding="latest">
      <bpmn:documentation>Dosen Koordinator merevisi RPS berdasarkan catatan dari level mana pun. Setelah revisi selesai, Dosen melakukan submit ulang yang kembali memulai rantai verifikasi dari Level 1.</bpmn:documentation>
