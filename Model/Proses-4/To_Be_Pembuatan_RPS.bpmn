      <bpmn:documentation id="documentation_RFqAKg"/>
    </bpmn:sequenceFlow>
    <bpmn:userTask id="T_KorprodiSetPloting" name="Korprodi Set Ploting&#10;Tim Dosen di SIMPEL&#10;(Dashboard)" ns1:candidateGroups="KPS" ns1:formRef="form_korprodi_set_ploting" ns1:formRefBinding="latest">
      <bpmn:documentation>Korprodi menetapkan ploting tim dosen di dashboard SIMPEL yang terintegrasi. Data dosen tersedia otomatis dari sistem sehingga Korprodi hanya perlu mengkonfirmasi penugasan.</bpmn:documentation>
      <bpmn:incoming>F_TB_RPS_02</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_03</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="T_AutoNotifDeadline" name="Sistem Kirim Reminder&#10;Deadline RPS H-7&#10;dan H-3">
      <bpmn:documentation>Sistem secara otomatis mengirim pengingat deadline ke Dosen Koordinator: pada H-7 dan H-3 sebelum batas waktu submit. Mengurangi keterlambatan akibat lupa.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var mk = execution.getVariable('mataKuliahRPS');
var dosen = execution.getVariable('dosenKoor');

JSON.stringify({
  "embeds": [{
    "title": "&#128226; [NOTIFIKASI OPERASIONAL] ⏱️ PROSES 4 -&gt; Broadcast Pengingat Batas Waktu",
    "description": "Sistem otomatis mengirimkan email pengingat pengisian konten substansi pembelajaran.",
    "color": 1752220,
    "fields": [
      { "name": "Mata Kuliah", "value": mk, "inline": true },
      { "name": "Dosen Koordinator", "value": dosen, "inline": true },
      { "name": "Status Pengingat", "value": "⏳ Reminder H-7 &amp; H-3 Terkirim", "inline": false }
    ],
    "footer": { "text": "SIMPEL Automated Notification Scheduler" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>F_TB_RPS_03</bpmn:incoming>
      <bpmn:outgoing>Flow_01wpjth</bpmn:outgoing>
      <bpmn:dataOutputAssociation id="DataOut_Reminder">
        <bpmn:targetRef>DataRef_Reminder_TB</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:serviceTask>
    <bpmn:sequenceFlow id="Flow_1r26osq" sourceRef="T_BoundaryTimerDosen" targetRef="T_EskalasiKorprodi">
      <bpmn:documentation id="documentation_N0PgTQ"/>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="Flow_1f7vk4j" sourceRef="T_DosenRevisiToBe" targetRef="SubProc_PenyusunanDraft">
      <bpmn:documentation id="documentation_sf00CQ"/>
    </bpmn:sequenceFlow>
    <bpmn:boundaryEvent attachedToRef="SubProc_PenyusunanDraft" id="T_BoundaryTimerDosen" name="Timer: Dosen&#10;Belum Submit&#10;di Deadline">
      <bpmn:documentation>Timer boundary event 14 hari (P14D). Jika Dosen Koordinator belum submit RPS dalam 14 hari setelah periode dimulai, sistem mengaktifkan jalur eskalasi ke Korprodi.</bpmn:documentation>
      <bpmn:outgoing>Flow_1r26osq</bpmn:outgoing>
      <bpmn:timerEventDefinition id="TimerEventDefinition_0sngtpr">
        <bpmn:timeDuration xsi:type="bpmn:tFormalExpression">PT5M</bpmn:timeDuration>
      </bpmn:timerEventDefinition>
    </bpmn:boundaryEvent>
    <bpmn:subProcess id="SubProc_PenyusunanDraft" name="Penyusunan Draft RPS">
      <bpmn:documentation id="documentation_KkFENw"/>
      <bpmn:incoming>Flow_01wpjth</bpmn:incoming>
      <bpmn:incoming>Flow_1f7vk4j</bpmn:incoming>
      <bpmn:outgoing>Flow_1ppnrix</bpmn:outgoing>
      <bpmn:userTask id="T_DosenInputSIMPEL" name="Dosen Input Konten&#10;RPS Langsung di&#10;Platform SIMPEL" ns1:candidateGroups="Dosen" ns1:formRef="form_dosen_input_rps" ns1:formRefBinding="latest">
        <bpmn:documentation>Dosen Koordinator mengisi konten RPS di SIMPEL. Pada TO-BE, sistem menampilkan progress pengisian dan validasi format secara real-time untuk membantu kelengkapan dokumen.</bpmn:documentation>
        <bpmn:incoming>Flow_0jybdy3</bpmn:incoming>
        <bpmn:outgoing>F_TB_RPS_dosen_in</bpmn:outgoing>
        <bpmn:property id="Property_1jfb7n4" name="__targetRef_placeholder"/>
