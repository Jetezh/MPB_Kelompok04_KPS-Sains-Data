              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var mk = execution.getVariable('mataKuliahRPS');

JSON.stringify({
  "embeds": [{
    "title": "🤖 [LOG SISTEM] 📚 PROSES 4 -&gt; Routing Berkas ke Level 1",
    "description": "Dosen Koordinator selesai melakukan submit konten lengkap. Token dialihkan ke meja verifikasi dokumen.",
    "color": 1752220,
    "fields": [
      { "name": "Mata Kuliah", "value": mk, "inline": true },
      { "name": "Tahapan Validasi", "value": "📥 Menunggu Pemeriksaan Struktur oleh Korprodi", "inline": true }
    ],
    "footer": { "text": "SIMPEL Workflow Dispatcher Engine" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>F_TB_RPS_05</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_06</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:endEvent id="EE_RPSPublished" name="RPS Final Dipublikasi&#10;ke Semua Pihak&#10;(Mahasiswa, Dosen)">
      <bpmn:documentation>RPS dipublikasikan ke semua pihak — mahasiswa dapat mengakses rencana pembelajaran di hari pertama semester, memenuhi hak mahasiswa atas kepastian rencana belajar.</bpmn:documentation>
      <bpmn:incoming>F_TB_RPS_end</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:serviceTask id="T_PublishRPS" name="Publish RPS ke&#10;Dashboard Mahasiswa&#10;dan Dosen">
      <bpmn:documentation>Sistem mempublikasikan RPS final ke dashboard dosen dan mahasiswa, memastikan seluruh stakeholder dapat mengakses rencana pembelajaran sejak hari pertama semester.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
