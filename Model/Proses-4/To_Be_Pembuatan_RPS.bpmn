<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" xmlns:ns1="http://camunda.org/schema/1.0/bpmn" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:open-bpmn="http://open-bpmn.org/XMLSchema" targetNamespace="http://fik.prodi.bpm/rps-simpel-to-be" exporter="Camunda Modeler" exporterVersion="5.44.0">
  <bpmn:collaboration id="Pembuatan_RPS">
    <bpmn:participant id="Pool_RPS_ToBe" name="Penyusunan dan Pengesahan RPS Digital via SIMPEL (TO-BE)" processRef="Proc_RPS_ToBe">
      <bpmn:documentation>Proses RPS SIMPEL pada kondisi TO-BE yang diperkuat dengan otomasi penuh: reminder deadline otomatis, timer boundary event untuk eskalasi jika dosen terlambat submit, auto-routing antar level, dan publikasi digital ke mahasiswa setelah pengesahan.</bpmn:documentation>
    </bpmn:participant>
    <bpmn:textAnnotation id="TextAnn_TimerEskalasi">
      <bpmn:documentation id="documentation_hIseig" />
      <bpmn:text>Timer 14 hari: jika dosen belum submit, sistem otomatis mengeskalasi ke Korprodi.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnn_AutoRoute">
      <bpmn:documentation id="documentation_CYp6sg" />
      <bpmn:text>Auto-routing ke reviewer berikutnya setelah setiap level approve — tidak perlu forward manual.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:textAnnotation id="TextAnn_Publish">
      <bpmn:documentation id="documentation_HpBopA" />
      <bpmn:text>RPS dipublikasikan ke dashboard mahasiswa sejak hari pertama semester — memenuhi hak mahasiswa.</bpmn:text>
    </bpmn:textAnnotation>
    <bpmn:association id="Assoc_Ann_TimerEsk" sourceRef="TextAnn_TimerEskalasi" targetRef="T_BoundaryTimerDosen" />
    <bpmn:association id="Assoc_Ann_AutoRoute" sourceRef="TextAnn_AutoRoute" targetRef="T_AutoRoute_L1" />
    <bpmn:association id="Assoc_Ann_Publish" sourceRef="TextAnn_Publish" targetRef="T_PublishRPS" />
  </bpmn:collaboration>
  <bpmn:process id="Proc_RPS_ToBe" name="RPS SIMPEL - TO-BE (Enhanced)" processType="Private" isExecutable="true" ns1:historyTimeToLive="30">
    <bpmn:laneSet id="LS_RPS_ToBe">
      <bpmn:lane id="Lane_Wadek_ToBe_RPS" name="Wakil Dekan 1 (Wadek 1)">
        <bpmn:documentation>Wadek 1 menerima routing otomatis dari sistem setelah Level 2 approve dan memberikan final approval digital.</bpmn:documentation>
        <bpmn:flowNodeRef>T_WadekApproveL3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_L3_ToBe</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_GKM_ToBe_RPS" name="Gugus Kendali Mutu (GKM)">
        <bpmn:documentation>GKM menerima routing otomatis dari sistem setelah Level 1 approve dan melakukan review substansi dengan mengisi catatan revisi digital.</bpmn:documentation>
        <bpmn:flowNodeRef>T_GKMReviewL2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_L2_ToBe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_GKMInputRevisiL2</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_DosenKoord_ToBe_RPS" name="Dosen Koordinator Mata Kuliah">
        <bpmn:documentation>Dosen Koordinator mengisi konten RPS di SIMPEL dan merespons catatan revisi. Terikat pada deadline yang didukung oleh sistem pengingat otomatis.</bpmn:documentation>
        <bpmn:flowNodeRef>T_DosenInputSIMPEL</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_DosenSubmit</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_BoundaryTimerDosen</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_DosenRevisiToBe</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Korprodi_ToBe_RPS" name="Koordinator Program Studi (Korprodi)">
        <bpmn:documentation>Korprodi menetapkan ploting dosen dan mereview draft RPS di dashboard. Menerima notifikasi eskalasi jika ada dosen yang melewati deadline.</bpmn:documentation>
        <bpmn:flowNodeRef>T_KorprodiReviewL1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>GW_L1_ToBe</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_KorprodiSetPloting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_KorprodiInputRevisiL1</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="Lane_Sistem_RPS" name="SISTEM SIMPEL (Automated)">
        <bpmn:documentation>Lane sistem yang mengelola: timer terjadwal untuk memulai periode RPS, notifikasi deadline otomatis (H-7 dan H-3), eskalasi jika dosen terlambat, auto-routing ke setiap level reviewer, generasi PDF final, dan publikasi ke dashboard.</bpmn:documentation>
        <bpmn:flowNodeRef>SE_SistemMulaiRPS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_AutoNotifPloting</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_EskalasiKorprodi</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_AutoNotifDeadline</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_AutoRoute_L1</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_AutoRoute_L2</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_AutoRoute_L3</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>EE_RPSPublished</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_PublishRPS</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>T_GeneratePDFFinal</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="SE_SistemMulaiRPS" name="Sistem Mulai&#10;Periode RPS&#10;(Timer Terjadwal)" ns1:formRef="form_start_rps" ns1:formRefBinding="latest">
      <bpmn:documentation>Timer terjadwal sistem yang secara otomatis memulai periode penyusunan RPS sesuai kalender akademik. Memastikan proses dimulai tepat waktu tanpa perlu inisiatif manual.</bpmn:documentation>
      <bpmn:outgoing>F_TB_RPS_01</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:serviceTask id="T_AutoNotifPloting" name="Sistem Kirim Notif&#10;Ploting ke Semua&#10;Dosen Koordinator">
      <bpmn:documentation>Sistem mengirim notifikasi otomatis ke semua Dosen Koordinator yang di-plot, memberitahukan bahwa periode penyusunan RPS telah dimulai beserta informasi mata kuliah dan deadline.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">// Variabel diambil dari form Start Event

// Inisialisasi variabel siklus kurikulum RPS

var mk = execution.getVariable('mataKuliahRPS');
var dosen = execution.getVariable('dosenKoor');

JSON.stringify({
  "embeds": [{
    "title": "烙 [LOG SISTEM]  PROSES 4 -&gt; Inisialisasi Periode RPS",
    "description": "Siklus penyusunan RPS digital resmi dibuka oleh sistem SIMPEL.",
    "color": 1752220,
    "fields": [
      { "name": "Mata Kuliah Target", "value": mk, "inline": true },
      { "name": "Dosen Koordinator", "value": dosen, "inline": true }
    ],
    "footer": { "text": "SIMPEL Engine V2 - Periode Akademik Aktif" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>F_TB_RPS_01</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_02</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="T_EskalasiKorprodi" name="Eskalasi Otomatis&#10;ke Korprodi:&#10;Dosen Belum Submit">
      <bpmn:documentation>Sistem mengirim notifikasi eskalasi ke Korprodi: dosen belum submit RPS mendekati deadline. Korprodi dapat langsung menghubungi dosen melalui informasi kontak yang tersedia di sistem.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var mk = execution.getVariable('mataKuliahRPS');
var dosen = execution.getVariable('dosenKoor');

JSON.stringify({
  "embeds": [{
    "title": " [ ALERT ESKALASI]  PROSES 4 -&gt; Pelanggaran Batas Waktu Submit RPS",
    "description": "Dosen Koordinator melewati batas tenggat waktu 14 hari. Pembuatan dokumen dialihkan pengawasannya ke pimpinan prodi.",
    "color": 12597547,
    "fields": [
      { "name": "Mata Kuliah", "value": mk, "inline": true },
      { "name": "Dosen Penanggungjawab", "value": dosen, "inline": true },
      { "name": "Tindakan Sistem", "value": "⚠️ Tiket darurat diterbitkan ke meja Korprodi (`g4kps`)", "inline": false }
    ],
    "footer": { "text": "SLA Monitor Component - Level: HIGH" }
  }]
});</ns1:script>
            </ns1:inputParameter>
          </ns1:inputOutput>
          <ns1:connectorId>http-connector</ns1:connectorId>
        </ns1:connector>
      </bpmn:extensionElements>
      <bpmn:incoming>F_TB_RPS_eskalasi</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_back</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="T_KorprodiReviewL1" name="Level 1: Korprodi&#10;Review RPS di&#10;Dashboard SIMPEL" ns1:formRef="form_korprodi_review_l1" ns1:formRefBinding="latest" ns1:candidateGroups="KPS">
      <bpmn:documentation>Korprodi mereview RPS di dashboard SIMPEL. Semua informasi yang dibutuhkan tersedia di satu tampilan: ploting dosen, kode MK, distribusi SKS, dan konten RPS.</bpmn:documentation>
      <bpmn:incoming>F_TB_RPS_06</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_l1</bpmn:outgoing>
      <bpmn:property id="Property_1wcr79w" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_154r0qo">
        <bpmn:sourceRef>DataRef_RPSDraft_TB</bpmn:sourceRef>
        <bpmn:targetRef>Property_1wcr79w</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="GW_L1_ToBe" name="L1 Approve?">
      <bpmn:documentation>Keputusan Level 1: approve atau perlu revisi? Catatan revisi dimasukkan langsung ke sistem dan dikirim otomatis ke Dosen Koordinator.</bpmn:documentation>
      <bpmn:incoming>F_TB_RPS_l1</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_l1ya</bpmn:outgoing>
      <bpmn:outgoing>F_TB_RPS_l1tidak</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="T_DosenInputSIMPEL" name="Dosen Input Konten&#10;RPS Langsung di&#10;Platform SIMPEL" ns1:formRef="form_dosen_input_rps" ns1:formRefBinding="latest" ns1:candidateGroups="Dosen">
      <bpmn:documentation>Dosen Koordinator mengisi konten RPS di SIMPEL. Pada TO-BE, sistem menampilkan progress pengisian dan validasi format secara real-time untuk membantu kelengkapan dokumen.</bpmn:documentation>
      <bpmn:incoming>F_TB_RPS_04</bpmn:incoming>
      <bpmn:incoming>F_TB_RPS_back</bpmn:incoming>
      <bpmn:incoming>F_TB_RPS_revdosen</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_dosen_in</bpmn:outgoing>
      <bpmn:property id="Property_125r9r1" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_12mvegc">
        <bpmn:sourceRef>DataRef_Reminder_TB</bpmn:sourceRef>
        <bpmn:targetRef>Property_125r9r1</bpmn:targetRef>
      </bpmn:dataInputAssociation>
      <bpmn:dataOutputAssociation id="DataOut_DosenInput">
        <bpmn:targetRef>DataRef_RPSDraft_TB</bpmn:targetRef>
      </bpmn:dataOutputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_DosenSubmit" name="Dosen Klik Submit&#10;Setelah Konten&#10;Lengkap" ns1:formRef="form_dosen_submit_rps" ns1:formRefBinding="latest" ns1:candidateGroups="Dosen">
      <bpmn:documentation>Dosen Koordinator menekan tombol Submit setelah konten RPS lengkap. Sistem otomatis memvalidasi kelengkapan isian sebelum memproses pengajuan.</bpmn:documentation>
      <bpmn:incoming>F_TB_RPS_dosen_in</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_05</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="T_GKMReviewL2" name="Level 2: GKM Review&#10;Substansi dan&#10;Sub-CPMK" ns1:formRef="form_gkm_review_l2" ns1:formRefBinding="latest" ns1:assignee="gkm">
      <bpmn:documentation>GKM mereview substansi akademik RPS di dashboard: kecukupan Sub-CPMK, relevansi konten per pertemuan, dan kesesuaian instrumen asesmen dengan bobot SKS.</bpmn:documentation>
      <bpmn:incoming>F_TB_RPS_08</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_l2</bpmn:outgoing>
      <bpmn:property id="Property_0kutsv5" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_1miuedx">
        <bpmn:sourceRef>DataRef_RPSDraft_TB</bpmn:sourceRef>
        <bpmn:targetRef>Property_0kutsv5</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_WadekApproveL3" name="Level 3: Wadek 1&#10;Final Approval&#10;di SIMPEL" ns1:formRef="form_wadek_approve_l3" ns1:formRefBinding="latest" ns1:candidateGroups="Pimpinan">
      <bpmn:documentation>Wadek 1 memberikan final approval digital di SIMPEL setelah memverifikasi bahwa seluruh rantai kendali mutu (Level 1 dan 2) telah terpenuhi.</bpmn:documentation>
      <bpmn:incoming>F_TB_RPS_10</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_l3</bpmn:outgoing>
      <bpmn:property id="Property_1cnz021" name="__targetRef_placeholder" />
      <bpmn:dataInputAssociation id="DataInputAssociation_0pe1265">
        <bpmn:sourceRef>DataRef_RPSDraft_TB</bpmn:sourceRef>
        <bpmn:targetRef>Property_1cnz021</bpmn:targetRef>
      </bpmn:dataInputAssociation>
    </bpmn:userTask>
    <bpmn:userTask id="T_KorprodiSetPloting" name="Korprodi Set Ploting&#10;Tim Dosen di SIMPEL&#10;(Dashboard)" ns1:formRef="form_korprodi_set_ploting" ns1:formRefBinding="latest" ns1:candidateGroups="KPS">
      <bpmn:documentation>Korprodi menetapkan ploting tim dosen di dashboard SIMPEL yang terintegrasi. Data dosen tersedia otomatis dari sistem sehingga Korprodi hanya perlu mengkonfirmasi penugasan.</bpmn:documentation>
      <bpmn:incoming>F_TB_RPS_02</bpmn:incoming>
      <bpmn:outgoing>F_TB_RPS_03</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:dataObjectReference id="DataRef_RPSDraft_TB" name="Draft RPS (SIMPEL TO-BE)" dataObjectRef="DataObject_RPSDraft_TB">
      <bpmn:documentation>Draft RPS di SIMPEL dengan validasi format real-time. Sistem menampilkan progress kelengkapan dan peringatan jika ada bagian yang kurang.</bpmn:documentation>
    </bpmn:dataObjectReference>
    <bpmn:dataObject id="DataObject_RPSDraft_TB">
      <bpmn:documentation id="documentation_uc0tUg" />
    </bpmn:dataObject>
    <bpmn:sequenceFlow id="F_TB_RPS_01" sourceRef="SE_SistemMulaiRPS" targetRef="T_AutoNotifPloting">
      <bpmn:documentation id="documentation_gD0BmQ" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_02" sourceRef="T_AutoNotifPloting" targetRef="T_KorprodiSetPloting">
      <bpmn:documentation id="documentation_XEqLzg" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_03" sourceRef="T_KorprodiSetPloting" targetRef="T_AutoNotifDeadline">
      <bpmn:documentation id="documentation_GWgkeQ" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_04" sourceRef="T_AutoNotifDeadline" targetRef="T_DosenInputSIMPEL">
      <bpmn:documentation id="documentation_lOgtFQ" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_eskalasi" sourceRef="T_BoundaryTimerDosen" targetRef="T_EskalasiKorprodi">
      <bpmn:documentation id="documentation_Ltu3OQ" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_back" sourceRef="T_EskalasiKorprodi" targetRef="T_DosenInputSIMPEL">
      <bpmn:documentation id="documentation_T0oqsw" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_l1ya" name="Approve" sourceRef="GW_L1_ToBe" targetRef="T_AutoRoute_L2">
      <bpmn:documentation id="documentation_7037SQ" />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isL1Approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_08" sourceRef="T_AutoRoute_L2" targetRef="T_GKMReviewL2">
      <bpmn:documentation id="documentation_vRS0PA" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_10" sourceRef="T_AutoRoute_L3" targetRef="T_WadekApproveL3">
      <bpmn:documentation id="documentation_Gr4pyQ" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_06" sourceRef="T_AutoRoute_L1" targetRef="T_KorprodiReviewL1">
      <bpmn:documentation id="documentation_qsC7Vg" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_l1" sourceRef="T_KorprodiReviewL1" targetRef="GW_L1_ToBe">
      <bpmn:documentation id="documentation_FddFjg" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_l1tidak" name="Revisi" sourceRef="GW_L1_ToBe" targetRef="T_KorprodiInputRevisiL1">
      <bpmn:documentation id="documentation_E5RVpg" />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isL1Approved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_revdosen" sourceRef="T_DosenRevisiToBe" targetRef="T_DosenInputSIMPEL">
      <bpmn:documentation id="documentation_VxfNaA" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_dosen_in" sourceRef="T_DosenInputSIMPEL" targetRef="T_DosenSubmit">
      <bpmn:documentation id="documentation_5By9Lg" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_05" sourceRef="T_DosenSubmit" targetRef="T_AutoRoute_L1">
      <bpmn:documentation id="documentation_pE3Y6g" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_rev3" name="Revisi" sourceRef="GW_L3_ToBe" targetRef="T_DosenRevisiToBe">
      <bpmn:documentation id="documentation_tU1sXw" />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isL3Approved == false}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_l2" sourceRef="T_GKMReviewL2" targetRef="GW_L2_ToBe">
      <bpmn:documentation id="documentation_pM0PoA" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_l3" sourceRef="T_WadekApproveL3" targetRef="GW_L3_ToBe">
      <bpmn:documentation id="documentation_0pExow" />
    </bpmn:sequenceFlow>
    <bpmn:sequenceFlow id="F_TB_RPS_l3ya" name="Approve" sourceRef="GW_L3_ToBe" targetRef="T_GeneratePDFFinal">
      <bpmn:documentation id="documentation_r0wSQw" />
      <bpmn:conditionExpression xsi:type="bpmn:tFormalExpression">${isL3Approved == true}</bpmn:conditionExpression>
    </bpmn:sequenceFlow>
    <bpmn:serviceTask id="T_AutoNotifDeadline" name="Sistem Kirim Reminder&#10;Deadline RPS H-7&#10;dan H-3">
      <bpmn:documentation>Sistem secara otomatis mengirim pengingat deadline ke Dosen Koordinator: pada H-7 dan H-3 sebelum batas waktu submit. Mengurangi keterlambatan akibat lupa.</bpmn:documentation>
      <bpmn:extensionElements>
        <ns1:connector>
          <ns1:inputOutput>
            <ns1:inputParameter name="url">https://discordapp.com/api/webhooks/1513419819246948354/dKnXD4cSnuxlsXLpmkMSc0IeShN17I--4dtoNhs1FY0v2HFo2rqGc8dnzaNMuw2Gv1m7</ns1:inputParameter>
            <ns1:inputParameter name="method">POST</ns1:inputParameter>
            <ns1:inputParameter name="headers">
              <ns1:map>
                <ns1:entry key="Content-Type">application/json</ns1:entry>
              </ns1:map>
            </ns1:inputParameter>
            <ns1:inputParameter name="payload">
              <ns1:script scriptFormat="javascript">var mk = execution.getVariable('mataKuliahRPS');
var dosen = execution.getVariable('dosenKoor');

JSON.stringify({
  "embeds": [{
    "title": " [NOTIFIKASI OPERASIONAL]  PROSES 4 -&gt; Broadcast Pengingat Batas Waktu",
